<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Fellowship Application Accepted</title>
</head>
<body style="margin:0; padding:0; background-color:#111111; font-family:system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#111111; padding:24px 0;">
    <tr>
      <td align="center">

        <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#1b1b1b; border-radius:16px; overflow:hidden;">
          <tr>
            <td align="center" style="background-color:#000000; padding:24px 24px 20px 24px;">
              <h1 style="margin:0; font-size:24px; color:#ffffff; font-weight:700;">
                Congratulations <%~ it.userName %>!
              </h1>
              <p style="margin:8px 0 0 0; font-size:14px; color:#f9b233; font-weight:500;">
                Your <%~ it.fellowshipType %> Fellowship Application Has Been Accepted
              </p>
            </td>
          </tr>

          <tr>
            <td style="padding:24px 32px 16px 32px; color:#eaeaea; font-size:14px; line-height:1.6;">
              <p style="margin:0 0 12px 0;">
                Hi <%~ it.userName %>,
              </p>

              <p style="margin:0 0 16px 0;">
                We are excited to inform you that your application for the
                <strong style="color:#f9b233;"><%~ it.fellowshipType %> Fellowship</strong> has been accepted!
              </p>

              <p style="margin:0 0 16px 0;">
                To get started, please log in to your account and complete the fellowship onboarding form
                with your additional details.
              </p>

              <table cellpadding="0" cellspacing="0" border="0" align="center" style="margin:16px auto 8px auto;">
                <tr>
                  <td align="center" bgcolor="#f7931a" style="border-radius:999px;">
                    <a href="https://app.bitshala.org/"
                       style="display:inline-block; padding:12px 28px; font-size:15px; font-weight:600; color:#000000; text-decoration:none;">
                      Complete Onboarding
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="padding:0 32px 32px 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#262626; border-radius:12px;">
                <tr>
                  <td style="padding:16px 20px;">
                    <h3 style="margin:0 0 8px 0; font-size:16px; color:#ffd580;">Next Steps</h3>
                    <ul style="padding-left:18px; margin:8px 0 0 0; color:#eaeaea; font-size:13px; line-height:1.7;">
                      <li>Log in and fill out the fellowship onboarding form.</li>
                      <li>Provide your mentor contact, project details, and GitHub profile.</li>
                      <li>Once completed, you will be fully onboarded into the fellowship program.</li>
                    </ul>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
