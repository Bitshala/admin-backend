<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%~ it.cohortName %> <%~ it.season %> Feedback Survey</title>
</head>
<body style="margin:0; padding:0; background-color:#111111; font-family:system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">

  <!-- Full-width background -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#111111; padding:24px 0;">
    <tr>
      <td align="center">

        <!-- Main card -->
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#1b1b1b; border-radius:16px; overflow:hidden;">
          <!-- Header strip -->
          <tr>
            <td align="center" style="background-color:#000000; padding:24px 24px 20px 24px;">
              <h1 style="margin:0; font-size:22px; color:#ffffff; font-weight:700;">
                &#128172; Feedback Survey
              </h1>
              <p style="margin:8px 0 0 0; font-size:14px; color:#f9b233; font-weight:500;">
                <%~ it.cohortName %> <%~ it.season %>
              </p>
            </td>
          </tr>

          <!-- Body copy -->
          <tr>
            <td style="padding:24px 32px 16px 32px; color:#eaeaea; font-size:14px; line-height:1.6;">
              <p style="margin:0 0 16px 0;">
                Hello <strong style="color:#ffd580;"><%~ it.userName %></strong>,
              </p>

              <p style="margin:0 0 20px 0;">
                Thank you for being part of the Bitshala
                <strong style="color:#f9b233;"><%~ it.cohortName %> <%~ it.season %></strong> cohort!
                We hope you had a great learning experience.
              </p>

              <p style="margin:0 0 20px 0;">
                We'd love to hear your thoughts! Your feedback helps us improve the cohort experience
                for future participants.
              </p>

              <!-- CTA button -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 20px 0;">
                <tr>
                  <td align="center">
                    <a href="https://app.bitshala.org/" target="_blank"
                       style="display:inline-block; padding:14px 32px; background-color:#f9b233; color:#111111; font-size:15px; font-weight:700; text-decoration:none; border-radius:8px;">
                      Fill Out Feedback Survey
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin:0 0 16px 0;">
                Your honest input — what worked, what didn't, and what we can do better — is incredibly valuable to us.
              </p>

              <p style="margin:0 0 4px 0; font-weight:500;">
                Thank you for helping us make Bitshala better!
              </p>
            </td>
          </tr>

          <!-- Footer / sign-off -->
          <tr>
            <td style="padding:0 32px 28px 32px; color:#b3b3b3; font-size:14px; line-height:1.6;">
              <p style="margin:0;">
                Best regards,<br />
                <strong style="color:#eaeaea;">Team Bitshala</strong>
              </p>
            </td>
          </tr>

        </table>
        <!-- /Main card -->

      </td>
    </tr>
  </table>

</body>
</html>
